region               = "us-east-1"
ami_id               = "ami-XXXXXXXXXXXX"
instance_type        = "t2.micro"
iam_instance_profile = "INSTANCESNOW"

# Option 1: Use network layer state (run network/ apply first, same S3 backend)
use_network_state      = true
terraform_state_bucket = "your-terraform-state-bucket"

# Option 2: Pass IDs directly (set use_network_state = false)
# use_network_state   = false
# subnet_id           = "subnet-XXXXXXXXXXXX"
# security_group_ids  = ["sg-XXXXXXXXXXXX"]
